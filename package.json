{
  "name": "franchise-architect-football",
  "version": "1.0.0",
  "description": "Franchise Architect: Football - 100-year scalable NFL-style franchise simulation engine",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "node src/server.js",
    "start": "node src/server.js",
    "cli": "node src/index.js",
    "build:pages": "node scripts/build-pages.mjs",
    "smoke:pages": "node scripts/smoke-pages.mjs",
    "sim:100": "node src/index.js --years 100 --seed 2026 --export",
    "build:realism-profile": "node src/data/scripts/buildRealismProfile.js",
    "build:official-nfl-baseline": "node src/data/scripts/buildOfficialNfl2025Baseline.js",
    "etl:pfr": "node src/data/scripts/pfrEtl.js",
    "verify:realism": "node src/data/scripts/verifyRealism.js --seasons 12",
    "test": "node scripts/run-test-shard.mjs all",
    "test:core": "node scripts/run-test-shard.mjs core",
    "test:runtime": "node scripts/run-test-shard.mjs runtime",
    "test:sim": "node scripts/run-test-shard.mjs sim-contract",
    "test:sim:contract": "node scripts/run-test-shard.mjs sim-contract",
    "test:sim:realism": "node scripts/run-test-shard.mjs sim-realism",
    "test:long": "node scripts/run-test-shard.mjs long",
    "test:full": "node scripts/run-test-shard.mjs full",
    "test:studio": "node scripts/run-test-shard.mjs studio",
    "test:ui": "playwright test",
    "test:ui:headed": "playwright test --headed"
  },
  "private": true,
  "license": "UNLICENSED",
  "devDependencies": {
    "@playwright/test": "^1.61.1"
  }
}
